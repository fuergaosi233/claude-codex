{
  "name": "claude-codex-adapter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "claude-codex-adapter": "dist/src/adapter.mjs"
  },
  "scripts": {
    "dev": "tsx src/adapter.mts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome lint src test scripts",
    "format": "biome format --write src test scripts",
    "check": "biome check src test scripts",
    "check:fix": "biome check --write src test scripts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "test": "npm run build && node --test dist/test/*.mjs",
    "doctor": "node scripts/doctor.mjs",
    "smoke:real": "npm run build && node scripts/smoke-real-claude.mjs",
    "probe:capabilities": "npm run build && node scripts/probe-capabilities.mjs",
    "acceptance:local-remote": "npm run build && node scripts/acceptance-local-remote.mjs",
    "acceptance:gui-ssh-localhost": "npm run build && node scripts/acceptance-gui-ssh-localhost.mjs",
    "acceptance:ssh-runtime-matrix": "npm run build && node scripts/acceptance-ssh-runtime-matrix.mjs",
    "probe:codex-cli-remote": "npm run build && node scripts/probe-codex-cli-remote.mjs",
    "start": "node dist/src/adapter.mjs",
    "generate:schema": "codex app-server generate-ts --experimental --out generated/codex-app-server"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.143",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/node": "^24.13.2",
    "@types/ws": "^8.18.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitepress": "^1.6.4"
  },
  "engines": {
    "node": ">=24"
  }
}
